{
  "enabledPlugins": {
    "issueboss@issueboss-marketplace": true,
    "llm-wiki@llm-wiki-marketplace": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers-extended-cc@superpowers-extended-cc-marketplace": true
  },
  "extraKnownMarketplaces": {
    "issueboss-marketplace": {
      "source": {
        "path": "/Users/scotte/Development/Projects/IssueBoss",
        "source": "directory"
      }
    },
    "llm-wiki-marketplace": {
      "source": {
        "path": "/Users/scotte/Development/Projects/llm-wiki",
        "source": "directory"
      }
    },
    "superpowers-extended-cc-marketplace": {
      "source": {
        "repo": "pcvelz/superpowers",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/tokensave hook-pre-tool-use",
            "type": "command"
          }
        ],
        "matcher": "Agent"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/tokensave hook-stop",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/tokensave hook-prompt-submit",
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeGitInstructions": false,
  "outputStyle": "Concise",
  "permissions": {
    "allow": [
      "Bash(sed -n '*,*p' *)",
      "Read(/Users/scotte/.claude/skills/*)",
      "mcp__tokensave__tokensave_affected",

{
  "permissions": {
    "allow": [
      "Bash(sed -n '*,*p' *)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers-extended-cc@superpowers-extended-cc-marketplace": true
  },
  "extraKnownMarketplaces": {
    "superpowers-extended-cc-marketplace": {
      "source": {
        "source": "github",
        "repo": "pcvelz/superpowers"
      }
    }
  }
}

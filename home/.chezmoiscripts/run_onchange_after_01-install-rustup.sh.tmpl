#!/usr/bin/env bash
# ---------------------------------------------------------------------------------------------------------------------
# Install rustup
# ---------------------------------------------------------------------------------------------------------------------
{{- if .homeMachine }}
if ! test -f "{{ .chezmoi.homeDir }}/.cargo/bin/rustup"; then
  echo "Installing rustup..."
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
fi
{{ end }}

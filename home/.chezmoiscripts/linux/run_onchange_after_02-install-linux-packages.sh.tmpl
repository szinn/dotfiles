#!/usr/bin/env bash
# ---------------------------------------------------------------------------------------------------------------------
# Install linux applications
# ---------------------------------------------------------------------------------------------------------------------

if test -n "$(command -v go)"; then
  for app in github.com/arl/gitmux@latest; do
    export GOPATH="{{ .chezmoi.homeDir }}/.go"
    export GOBIN="$GOPATH/bin"

    go install "${app}"
  done
fi

sudo dnf copr enable scottames/ghostty -y
sudo dnf copr enable atim/lazygit -y
sudo dnf -q -y install lazygit ghostty podman podman-docker
sudo dnf -q -y group install development-tools
